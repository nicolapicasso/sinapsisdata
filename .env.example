# ============================================
# SINAPSIS DATA - Variables de Entorno
# ============================================
# Copia este archivo a .env y configura los valores

# --------------------------------------------
# BASE DE DATOS (PostgreSQL)
# --------------------------------------------
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Ejemplo local:
DATABASE_URL="postgresql://postgres:password@localhost:5432/sinapsis_data"
# Ejemplo DigitalOcean Managed Database:
# DATABASE_URL="postgresql://doadmin:PASSWORD@db-postgresql-xxx.ondigitalocean.com:25060/sinapsis_data?sslmode=require"

# --------------------------------------------
# NEXTAUTH (Autenticación)
# --------------------------------------------
# URL base de la aplicación (sin barra final)
NEXTAUTH_URL="http://localhost:3000"
# Secret para encriptar tokens - GENERAR UNO ÚNICO EN PRODUCCIÓN
# Puedes generar uno con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-muy-seguro-aqui-cambiar-en-produccion"

# --------------------------------------------
# ANTHROPIC (Claude AI)
# --------------------------------------------
# Tu API key de Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY="sk-ant-..."

# --------------------------------------------
# ALMACENAMIENTO
# --------------------------------------------
# Ruta donde se guardan archivos subidos
STORAGE_PATH="./storage"

# --------------------------------------------
# CONFIGURACIÓN DE LA APP
# --------------------------------------------
NEXT_PUBLIC_APP_NAME="Sinapsis Data"
# URL pública de la aplicación (para metadatos y links)
NEXT_PUBLIC_APP_URL="https://tu-dominio.com"

# --------------------------------------------
# CIFRADO DE TOKENS
# --------------------------------------------
# Clave para cifrar tokens OAuth (AES-256)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# --------------------------------------------
# GOOGLE ADS API
# --------------------------------------------
# Credenciales OAuth2 de Google Cloud Console
# Crear en: https://console.cloud.google.com/apis/credentials
GOOGLE_ADS_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_ADS_CLIENT_SECRET="your-client-secret"
# Token de desarrollador de Google Ads (solicitar en Google Ads API Center)
# https://developers.google.com/google-ads/api/docs/get-started/dev-token
GOOGLE_ADS_DEVELOPER_TOKEN="your-developer-token"

# --------------------------------------------
# GOOGLE ANALYTICS API
# --------------------------------------------
# Credenciales OAuth2 (pueden ser las mismas que Google Ads o separadas)
GOOGLE_ANALYTICS_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_ANALYTICS_CLIENT_SECRET="your-client-secret"

# --------------------------------------------
# DOCKER / PRODUCCIÓN
# --------------------------------------------
# Puerto donde correrá la app (por defecto 3000)
PORT=3000
# Modo de ejecución
NODE_ENV=production
